
@page "/invoices"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Timesheet.Data
@using Timesheet.Models
@using Timesheet.Services
@using Microsoft.AspNetCore.Authorization

@inject AppDbContext DbContext
@inject InvoicePdfService InvoicePdfService
@inject IJSRuntime JSRuntime

<PageTitle>Invoices</PageTitle>

<h1>Invoices</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card mb-4">
    <div class="card-header">
        Create Invoice
    </div>
    <div class="card-body">
        <form @onsubmit="CreateInvoiceAsync" @onsubmit:preventDefault="true">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="invoice-client">Client</label>
                    <select id="invoice-client" class="form-select" @bind="newInvoice.ClientId">
                        <option value="0">Select a client</option>
                        @foreach (var client in clients)
                        {
                            <option value="@client.Id">@client.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label" for="period-start">Period Start</label>
                    <input id="period-start" type="text" class="form-control" placeholder="yyyy-MM-dd" @bind="periodStartText" />
                </div>

                <div class="col-md-3">
                    <label class="form-label" for="period-end">Period End</label>
                    <input id="period-end" type="text" class="form-control" placeholder="yyyy-MM-dd" @bind="periodEndText" />
                </div>

                <div class="col-12">
                    <label class="form-label" for="invoice-notes">Notes</label>
                    <textarea id="invoice-notes" class="form-control" rows="3" @bind="newInvoice.Notes"></textarea>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary" disabled="@(clients.Count == 0)">Create Invoice</button>
                    <button type="button" class="btn btn-secondary ms-2" disabled="@(clients.Count == 0)" @onclick="PreviewInvoiceItemsAsync">Preview Invoice Items</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (previewWasLoaded)
{
    <div class="card mb-4">
        <div class="card-header">
            Invoice Preview
        </div>
        <div class="card-body">
            @if (previewEntries.Count == 0)
            {
                <div class="alert alert-warning mb-0">
                    No approved billable timesheet entries found for this client and period.
                </div>
            }
            else
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title text-muted">Total Preview Hours</h6>
                                <div class="fs-4 fw-bold">@PreviewTotalHours.ToString("N2")</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title text-muted">Total Preview Amount</h6>
                                <div class="fs-4 fw-bold">@PreviewTotalAmount.ToString("C")</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title text-muted">Invoice Items</h6>
                                <div class="fs-4 fw-bold">@previewEntries.Count</div>
                            </div>
                        </div>
                    </div>
                </div>

                <table class="table table-striped table-bordered mb-0">
                    <thead>
                        <tr>
                            <th>Work Date</th>
                            <th>Project</th>
                            <th>Activity Description</th>
                            <th>Workstream</th>
                            <th>Hours Worked</th>
                            <th>Hourly Rate</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in previewEntries)
                        {
                            <tr>
                                <td>@entry.WorkDate.ToString("yyyy-MM-dd")</td>
                                <td>@entry.Project?.Name</td>
                                <td>@entry.ActivityDescription</td>
                                <td>@entry.Workstream</td>
                                <td>@entry.HoursWorked.ToString("N2")</td>
                                <td>@entry.HourlyRate.ToString("C")</td>
                                <td>@entry.Amount.ToString("C")</td>
                                <td>@entry.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<div class="card">
    <div class="card-header">
        Saved Invoices
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered mb-0">
            <thead>
                <tr>
                    <th>Invoice Number</th>
                    <th>Client</th>
                    <th>Invoice Date</th>
                    <th>Period Start</th>
                    <th>Period End</th>
                    <th>Total Hours</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (invoices.Count == 0)
                {
                    <tr>
                        <td colspan="10" class="text-muted">No invoices have been created yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var invoice in invoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceNumber</td>
                            <td>@invoice.Client?.Name</td>
                            <td>@invoice.InvoiceDate.ToString("yyyy-MM-dd")</td>
                            <td>@invoice.PeriodStart.ToString("yyyy-MM-dd")</td>
                            <td>@invoice.PeriodEnd.ToString("yyyy-MM-dd")</td>
                            <td>@invoice.TotalHours.ToString("N2")</td>
                            <td>@invoice.TotalAmount.ToString("C")</td>
                            <td>@invoice.Status</td>
                            <td>@invoice.Notes</td>
                            <td>
                                <div class="d-flex gap-2 align-items-center flex-nowrap">
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ExportInvoicePdfAsync(invoice.Id)">
                                        Export PDF
                                    </button>

                                    @if (invoice.Status == "Draft")
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => UpdateInvoiceStatusAsync(invoice.Id, "Sent", "Invoice marked as Sent."))">
                                            Mark as Sent
                                        </button>
                                    }
                                    else if (invoice.Status == "Sent")
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-success" @onclick="@(() => UpdateInvoiceStatusAsync(invoice.Id, "Paid", "Invoice marked as Paid."))">
                                            Mark as Paid
                                        </button>
                                    }
                                    else if (invoice.Status == "Paid")
                                    {
                                        <span class="badge bg-success">Paid / Locked</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    window.downloadFileFromBase64 = (fileName, base64Data, contentType) => {
        const link = document.createElement('a');
        link.download = fileName;
        link.href = `data:${contentType};base64,${base64Data}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };
</script>

@code {
    private Invoice newInvoice = new();
    private List<Client> clients = [];
    private List<Invoice> invoices = [];
    private List<TimesheetEntry> previewEntries = [];
    private string periodStartText = DateTime.Today.ToString("yyyy-MM-dd");
    private string periodEndText = DateTime.Today.ToString("yyyy-MM-dd");
    private string? errorMessage;
    private string? successMessage;
    private bool previewWasLoaded;

    private decimal PreviewTotalHours => previewEntries.Sum(entry => entry.HoursWorked);
    private decimal PreviewTotalAmount => previewEntries.Sum(entry => entry.Amount);

    protected override async Task OnInitializedAsync()
    {
        await LoadClientsAsync();
        await LoadInvoicesAsync();
        ResetNewInvoice();
    }

    private async Task CreateInvoiceAsync()
    {
        errorMessage = null;
        successMessage = null;

        var previewLoaded = await LoadPreviewEntriesAsync();

        if (!previewLoaded)
        {
            return;
        }

        if (previewEntries.Count == 0)
        {
            errorMessage = "Cannot create an invoice because no approved billable timesheet entries were found for this client and period.";
            return;
        }

        newInvoice.InvoiceNumber = $"INV-{DateTime.UtcNow:yyyyMMdd-HHmmss}";
        newInvoice.InvoiceDate = DateTime.UtcNow;
        newInvoice.PeriodStart = DateTime.SpecifyKind(DateTime.Parse(periodStartText).Date, DateTimeKind.Utc);
        newInvoice.PeriodEnd = DateTime.SpecifyKind(DateTime.Parse(periodEndText).Date, DateTimeKind.Utc);
        newInvoice.TotalHours = PreviewTotalHours;
        newInvoice.TotalAmount = PreviewTotalAmount;
        newInvoice.Status = "Draft";
        newInvoice.CreatedAt = DateTime.UtcNow;

        DbContext.Invoices.Add(newInvoice);
        await DbContext.SaveChangesAsync();

        var invoiceLineItems = previewEntries.Select(entry => new InvoiceLineItem
        {
            InvoiceId = newInvoice.Id,
            TimesheetEntryId = entry.Id,
            WorkDate = entry.WorkDate,
            ProjectName = entry.Project?.Name ?? string.Empty,
            ActivityDescription = entry.ActivityDescription,
            Workstream = entry.Workstream,
            HoursWorked = entry.HoursWorked,
            HourlyRate = entry.HourlyRate,
            Amount = entry.Amount,
            CreatedAt = DateTime.UtcNow
        }).ToList();

        DbContext.InvoiceLineItems.AddRange(invoiceLineItems);

        foreach (var entry in previewEntries)
        {
            entry.Status = "Invoiced";
        }

        await DbContext.SaveChangesAsync();

        successMessage = "Invoice created successfully, line items saved, and timesheet entries marked as Invoiced.";

        await LoadInvoicesAsync();
        previewEntries = [];
        previewWasLoaded = false;
    }

    private async Task PreviewInvoiceItemsAsync()
    {
        errorMessage = null;
        successMessage = null;

        await LoadPreviewEntriesAsync();
    }

    private async Task ExportInvoicePdfAsync(int invoiceId)
    {
        errorMessage = null;
        successMessage = null;

        var invoice = await DbContext.Invoices
            .Include(invoice => invoice.Client)
            .FirstOrDefaultAsync(invoice => invoice.Id == invoiceId);

        if (invoice is null)
        {
            errorMessage = "Invoice could not be found.";
            return;
        }

        var lineItems = await DbContext.InvoiceLineItems
            .Where(lineItem => lineItem.InvoiceId == invoice.Id)
            .OrderBy(lineItem => lineItem.WorkDate)
            .ThenBy(lineItem => lineItem.Id)
            .ToListAsync();

        var companyProfile = await DbContext.CompanyProfiles
            .OrderBy(profile => profile.Id)
            .FirstOrDefaultAsync();

        var pdfBytes = InvoicePdfService.GenerateInvoicePdf(invoice, lineItems, companyProfile);
        var base64Pdf = Convert.ToBase64String(pdfBytes);
        var fileName = $"Invoice-{invoice.InvoiceNumber}.pdf";

        await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, base64Pdf, "application/pdf");
    }

    private async Task UpdateInvoiceStatusAsync(int invoiceId, string status, string message)
    {
        errorMessage = null;
        successMessage = null;

        var invoice = await DbContext.Invoices
            .FirstOrDefaultAsync(invoice => invoice.Id == invoiceId);

        if (invoice is null)
        {
            errorMessage = "Invoice could not be found.";
            return;
        }

        invoice.Status = status;
        await DbContext.SaveChangesAsync();

        successMessage = message;
        await LoadInvoicesAsync();
    }

    private async Task<bool> LoadPreviewEntriesAsync()
    {
        previewWasLoaded = false;
        previewEntries = [];

        if (newInvoice.ClientId == 0)
        {
            errorMessage = "Please select a client.";
            return false;
        }

        if (!DateTime.TryParse(periodStartText, out var periodStart))
        {
            errorMessage = "Please enter a valid period start date.";
            return false;
        }

        if (!DateTime.TryParse(periodEndText, out var periodEnd))
        {
            errorMessage = "Please enter a valid period end date.";
            return false;
        }

        if (periodEnd < periodStart)
        {
            errorMessage = "Period end must be on or after period start.";
            return false;
        }

        var utcPeriodStart = DateTime.SpecifyKind(periodStart.Date, DateTimeKind.Utc);
        var utcPeriodEnd = DateTime.SpecifyKind(periodEnd.Date, DateTimeKind.Utc);

        previewEntries = await DbContext.TimesheetEntries
            .Include(entry => entry.Project)
            .ThenInclude(project => project.Client)
            .Where(entry =>
                entry.Project.ClientId == newInvoice.ClientId &&
                entry.WorkDate >= utcPeriodStart &&
                entry.WorkDate <= utcPeriodEnd &&
                entry.IsBillable &&
                entry.Status == "Approved")
            .OrderBy(entry => entry.WorkDate)
            .ThenBy(entry => entry.Id)
            .ToListAsync();

        previewWasLoaded = true;
        return true;
    }

    private async Task LoadClientsAsync()
    {
        clients = await DbContext.Clients
            .OrderBy(client => client.Name)
            .ToListAsync();
    }

    private async Task LoadInvoicesAsync()
    {
        invoices = await DbContext.Invoices
            .Include(invoice => invoice.Client)
            .OrderByDescending(invoice => invoice.InvoiceDate)
            .ToListAsync();
    }

    private void ResetNewInvoice()
    {
        newInvoice = new Invoice
        {
            ClientId = clients.FirstOrDefault()?.Id ?? 0
        };

        periodStartText = DateTime.Today.ToString("yyyy-MM-dd");
        periodEndText = DateTime.Today.ToString("yyyy-MM-dd");
        previewEntries = [];
        previewWasLoaded = false;
    }
}
