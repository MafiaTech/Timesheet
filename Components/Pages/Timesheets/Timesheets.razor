@page "/timesheets"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Timesheet.Data
@using Timesheet.Models
@using Timesheet.Services
@using Microsoft.AspNetCore.Authorization

@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject EmailService EmailService
@inject NavigationManager NavigationManager

<h3>Timesheet Entries</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card mb-4">
    <div class="card-header">
        @(isEditMode ? "Edit Timesheet Entry" : "Add Timesheet Entry")
    </div>
    <div class="card-body">
        <form @onsubmit="SaveTimesheetEntryAsync" @onsubmit:preventDefault="true">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Project</label>
                    <select class="form-select" @bind="newEntry.ProjectId">
                        <option value="0">-- Select project --</option>
                        @foreach (var project in projects)
                        {
                            <option value="@project.Id">
                                @project.Client?.Name - @project.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Work Date</label>
                    <input type="text" class="form-control" placeholder="yyyy-MM-dd" @bind="workDateText" />
                    <div class="form-text">Only completed work can be captured. Future dates are not allowed.</div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-12">
                    <label class="form-label">Workstream</label>
                    <input type="text" class="form-control" @bind="newEntry.Workstream" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Activity Description</label>
                <textarea class="form-control" rows="3" @bind="newEntry.ActivityDescription"></textarea>
            </div>

            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Start Time</label>
                    <input type="text" class="form-control" placeholder="HH:mm" @bind="startTimeText" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">End Time</label>
                    <input type="text" class="form-control" placeholder="HH:mm" @bind="endTimeText" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Hourly Rate</label>
                    <input type="number" step="0.01" class="form-control" @bind="newEntry.HourlyRate" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Billable</label>
                    <div class="form-check mt-2">
                        <input type="checkbox" class="form-check-input" @bind="newEntry.IsBillable" />
                        <label class="form-check-label">Yes</label>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea class="form-control" rows="2" @bind="newEntry.Notes"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">@(isEditMode ? "Update Timesheet Entry" : "Save Timesheet Entry")</button>
            @if (isEditMode)
            {
                <button type="button" class="btn btn-secondary ms-2" @onclick="CancelEdit">Cancel Edit</button>
            }
        </form>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        Send Timesheet for Approval
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Client</label>
                <select class="form-select" @bind="approvalClientId">
                    <option value="0">-- Select client --</option>
                    @foreach (var client in clients)
                    {
                        <option value="@client.Id">@client.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Period Start</label>
                <input type="text" class="form-control" placeholder="yyyy-MM-dd" @bind="approvalPeriodStartText" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Period End</label>
                <input type="text" class="form-control" placeholder="yyyy-MM-dd" @bind="approvalPeriodEndText" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-primary" @onclick="SendTimesheetForApprovalAsync">Send for Approval</button>
            </div>
        </div>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Work Date</th>
            <th>Client</th>
            <th>Project</th>
            <th>Workstream</th>
            <th>Activity</th>
            <th>Start</th>
            <th>End</th>
            <th>Hours</th>
            <th>Billable</th>
            <th>Rate</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var entry in timesheetEntries)
        {
            <tr>
                <td>@entry.WorkDate.ToString("yyyy-MM-dd")</td>
                <td>@entry.Project?.Client?.Name</td>
                <td>@entry.Project?.Name</td>
                <td>@entry.Workstream</td>
                <td>@entry.ActivityDescription</td>
                <td>@entry.StartTime.ToString(@"hh\:mm")</td>
                <td>@entry.EndTime.ToString(@"hh\:mm")</td>
                <td>@entry.HoursWorked</td>
                <td>@(entry.IsBillable ? "Yes" : "No")</td>
                <td>@entry.HourlyRate.ToString("C")</td>
                <td>@entry.Amount.ToString("C")</td>
                <td>@entry.Status</td>
                <td>
                    <div class="d-flex gap-2 align-items-center flex-nowrap">
                        @if (CanEditOrDelete(entry.Status))
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => EditTimesheetEntry(entry.Id)">Edit</button>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTimesheetEntryAsync(entry.Id)">Delete</button>
                        }
                        else if (entry.Status == "Submitted")
                        {
                            <span class="badge bg-warning text-dark">Awaiting Approval</span>
                        }
                        else if (entry.Status == "Approved")
                        {
                            <span class="badge bg-success">Approved / Locked</span>
                        }
                        else if (entry.Status == "Invoiced")
                        {
                            <span class="badge bg-secondary">Invoiced / Locked</span>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private TimesheetEntry newEntry = new();
    private List<Timesheet.Models.Project> projects = new();
    private List<Client> clients = new();
    private List<TimesheetEntry> timesheetEntries = new();

    private string workDateText = DateTime.Today.ToString("yyyy-MM-dd");
    private string startTimeText = "08:00";
    private string endTimeText = "17:00";
    private int approvalClientId;
    private string approvalPeriodStartText = DateTime.Today.ToString("yyyy-MM-dd");
    private string approvalPeriodEndText = DateTime.Today.ToString("yyyy-MM-dd");
    private string? errorMessage;
    private string? successMessage;
    private bool isEditMode = false;
    private int? editingEntryId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        newEntry.IsBillable = true;
        newEntry.Status = "Draft";
    }

    private async Task LoadDataAsync()
    {
        clients = await DbContext.Clients
            .OrderBy(client => client.Name)
            .ToListAsync();

        projects = await DbContext.Projects
            .Include(p => p.Client)
            .OrderBy(p => p.Name)
            .ToListAsync();

        timesheetEntries = await DbContext.TimesheetEntries
            .Include(t => t.Project)
            .ThenInclude(p => p.Client)
            .OrderByDescending(t => t.WorkDate)
            .ToListAsync();
    }

    private async Task SendTimesheetForApprovalAsync()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            if (approvalClientId == 0)
            {
                errorMessage = "Please select a client.";
                return;
            }

            if (!DateTime.TryParse(approvalPeriodStartText, out var periodStart))
            {
                errorMessage = "Please enter a valid period start date.";
                return;
            }

            if (!DateTime.TryParse(approvalPeriodEndText, out var periodEnd))
            {
                errorMessage = "Please enter a valid period end date.";
                return;
            }

            if (periodEnd < periodStart)
            {
                errorMessage = "Period end must be on or after period start.";
                return;
            }

            var client = await DbContext.Clients
                .FirstOrDefaultAsync(client => client.Id == approvalClientId);

            if (client is null)
            {
                errorMessage = "Client not found.";
                return;
            }

            if (string.IsNullOrWhiteSpace(client.Email))
            {
                errorMessage = "Selected client does not have an email address.";
                return;
            }

            var periodStartDate = periodStart.Date;
            var periodEndDate = periodEnd.Date;
            var utcPeriodStart = DateTime.SpecifyKind(periodStartDate, DateTimeKind.Utc);
            var utcPeriodEnd = DateTime.SpecifyKind(periodEndDate, DateTimeKind.Utc);

            var draftBillableEntries = await DbContext.TimesheetEntries
                .Include(entry => entry.Project)
                .ThenInclude(project => project.Client)
                .Where(entry =>
                    entry.Project.ClientId == approvalClientId &&
                    entry.Status == "Draft" &&
                    entry.IsBillable)
                .OrderBy(entry => entry.WorkDate)
                .ThenBy(entry => entry.Id)
                .ToListAsync();

            var approvalEntries = draftBillableEntries
                .Where(entry =>
                    entry.WorkDate.Date >= periodStartDate &&
                    entry.WorkDate.Date <= periodEndDate)
                .ToList();

            if (approvalEntries.Count == 0)
            {
                errorMessage = "No draft billable timesheet entries found for this client and period.";
                return;
            }

            var approvalRequest = new TimesheetApprovalRequest
            {
                ClientId = client.Id,
                ApprovalToken = Guid.NewGuid().ToString("N"),
                PeriodStart = utcPeriodStart,
                PeriodEnd = utcPeriodEnd,
                Status = "Pending",
                SentToEmail = client.Email,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.TimesheetApprovalRequests.Add(approvalRequest);
            await DbContext.SaveChangesAsync();

            var approvalLink = NavigationManager.BaseUri + $"approve-timesheet/{approvalRequest.ApprovalToken}";
            var greetingName = string.IsNullOrWhiteSpace(client.ContactPerson)
                ? client.Name
                : client.ContactPerson;
            var totalHours = approvalEntries.Sum(entry => entry.HoursWorked);
            var totalAmount = approvalEntries.Sum(entry => entry.Amount);
            var subject = $"Timesheet Approval Request - {client.Name}";
            var htmlBody = $"""
                <p>Hi {greetingName},</p>
                <p>Please review the timesheet submitted by GM Technologies.</p>
                <p><strong>Period Start:</strong> {utcPeriodStart:yyyy-MM-dd}<br />
                <strong>Period End:</strong> {utcPeriodEnd:yyyy-MM-dd}<br />
                <strong>Total Hours:</strong> {totalHours:N2}<br />
                <strong>Total Amount:</strong> {totalAmount:C}</p>
                <p><a href="{approvalLink}">Review and approve timesheet</a></p>
                <p>Regards,<br />GM Technologies</p>
                """;

            await EmailService.SendEmailAsync(client.Email, subject, htmlBody);

            foreach (var entry in approvalEntries)
            {
                entry.Status = "Submitted";
                entry.TimesheetApprovalRequestId = approvalRequest.Id;
            }

            await DbContext.SaveChangesAsync();
            await LoadDataAsync();

            successMessage = "Timesheet sent for approval successfully.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private async Task SaveTimesheetEntryAsync()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            if (!TryPrepareEntryValues(out var workDate, out var startTime, out var endTime, out var hoursWorked, out var amount))
            {
                return;
            }

            if (isEditMode)
            {
                if (editingEntryId is null)
                {
                    errorMessage = "No timesheet entry is selected for editing.";
                    return;
                }

                var existingEntry = await DbContext.TimesheetEntries
                    .FirstOrDefaultAsync(entry => entry.Id == editingEntryId.Value);

                if (existingEntry is null)
                {
                    errorMessage = "Timesheet entry could not be found.";
                    return;
                }

                if (!CanEditOrDelete(existingEntry.Status))
                {
                    errorMessage = "Only Draft or Rejected timesheet entries can be edited.";
                    return;
                }

                existingEntry.ProjectId = newEntry.ProjectId;
                existingEntry.WorkDate = DateTime.SpecifyKind(workDate, DateTimeKind.Utc);
                existingEntry.Workstream = newEntry.Workstream;
                existingEntry.ActivityDescription = newEntry.ActivityDescription;
                existingEntry.StartTime = startTime;
                existingEntry.EndTime = endTime;
                existingEntry.HoursWorked = hoursWorked;
                existingEntry.IsBillable = newEntry.IsBillable;
                existingEntry.HourlyRate = newEntry.HourlyRate;
                existingEntry.Amount = amount;
                existingEntry.Notes = newEntry.Notes;

                await DbContext.SaveChangesAsync();

                successMessage = "Timesheet entry updated successfully.";
                ResetForm();
                await LoadDataAsync();
                return;
            }

            newEntry.WorkDate = DateTime.SpecifyKind(workDate, DateTimeKind.Utc);
            newEntry.StartTime = startTime;
            newEntry.EndTime = endTime;
            newEntry.HoursWorked = hoursWorked;
            newEntry.Amount = amount;
            newEntry.Status = "Draft";
            newEntry.CreatedAt = DateTime.UtcNow;

            DbContext.TimesheetEntries.Add(newEntry);
            await DbContext.SaveChangesAsync();

            ResetForm();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private bool TryPrepareEntryValues(out DateTime workDate, out TimeSpan startTime, out TimeSpan endTime, out decimal hoursWorked, out decimal amount)
    {
        workDate = default;
        startTime = default;
        endTime = default;
        hoursWorked = 0;
        amount = 0;

        if (newEntry.ProjectId == 0)
        {
            errorMessage = "Please select a project.";
            return false;
        }

        if (!DateTime.TryParse(workDateText, out workDate))
        {
            errorMessage = "Please enter a valid work date.";
            return false;
        }

        if (workDate.Date > DateTime.Today)
        {
            errorMessage = "Future work dates are not allowed. Please capture only completed work.";
            return false;
        }

        if (!TimeSpan.TryParse(startTimeText, out startTime))
        {
            errorMessage = "Please enter a valid start time.";
            return false;
        }

        if (!TimeSpan.TryParse(endTimeText, out endTime))
        {
            errorMessage = "Please enter a valid end time.";
            return false;
        }

        if (endTime <= startTime)
        {
            errorMessage = "End time must be after start time.";
            return false;
        }

        hoursWorked = (decimal)(endTime - startTime).TotalHours;
        amount = newEntry.IsBillable
            ? hoursWorked * newEntry.HourlyRate
            : 0;

        return true;
    }

    private async Task EditTimesheetEntry(int entryId)
    {
        errorMessage = null;
        successMessage = null;

        var entry = await DbContext.TimesheetEntries
            .AsNoTracking()
            .FirstOrDefaultAsync(entry => entry.Id == entryId);

        if (entry is null)
        {
            errorMessage = "Timesheet entry could not be found.";
            return;
        }

        if (!CanEditOrDelete(entry.Status))
        {
            errorMessage = "Only Draft or Rejected timesheet entries can be edited.";
            return;
        }

        newEntry = new TimesheetEntry
        {
            ProjectId = entry.ProjectId,
            WorkDate = entry.WorkDate,
            Workstream = entry.Workstream,
            ActivityDescription = entry.ActivityDescription,
            StartTime = entry.StartTime,
            EndTime = entry.EndTime,
            HoursWorked = entry.HoursWorked,
            IsBillable = entry.IsBillable,
            HourlyRate = entry.HourlyRate,
            Amount = entry.Amount,
            Notes = entry.Notes
        };

        isEditMode = true;
        editingEntryId = entry.Id;
        workDateText = entry.WorkDate.ToString("yyyy-MM-dd");
        startTimeText = entry.StartTime.ToString(@"hh\:mm");
        endTimeText = entry.EndTime.ToString(@"hh\:mm");
    }

    private async Task DeleteTimesheetEntryAsync(int entryId)
    {
        errorMessage = null;
        successMessage = null;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this timesheet entry?");

        if (!confirmed)
        {
            return;
        }

        var entry = await DbContext.TimesheetEntries
            .FirstOrDefaultAsync(entry => entry.Id == entryId);

        if (entry is null)
        {
            errorMessage = "Timesheet entry not found.";
            return;
        }

        if (!CanEditOrDelete(entry.Status))
        {
            errorMessage = "Only Draft or Rejected timesheet entries can be deleted.";
            return;
        }

        DbContext.TimesheetEntries.Remove(entry);
        await DbContext.SaveChangesAsync();

        successMessage = "Timesheet entry deleted successfully.";

        if (editingEntryId == entryId)
        {
            ResetForm();
        }

        await LoadDataAsync();
    }

    private void CancelEdit()
    {
        errorMessage = null;
        successMessage = null;
        ResetForm();
    }

    private void ResetForm()
    {
        newEntry = new TimesheetEntry
        {
            IsBillable = true,
            Status = "Draft"
        };

        workDateText = DateTime.Today.ToString("yyyy-MM-dd");
        startTimeText = "08:00";
        endTimeText = "17:00";
        isEditMode = false;
        editingEntryId = null;
    }

    private static bool CanEditOrDelete(string status)
    {
        return status == "Draft" || status == "Rejected";
    }
}
